# Keyraft Configuration Example
# Copy this to .env and update values

# Master encryption key (REQUIRED for production)
# Generate with: openssl rand -base64 32
KEYRAFT_MASTER_KEY=your-secure-32-byte-key-here

# Data directory (optional, defaults to ./data)
# KEYRAFT_DATA_DIR=/var/lib/keyraft

# Listen address (optional, defaults to :7200)
# KEYRAFT_LISTEN=:7200

